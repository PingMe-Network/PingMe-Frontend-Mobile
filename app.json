{
  "expo": {
    "name": "Ping Me",
    "slug": "Ping-Me",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "scheme": "pingme",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "PingMe can use your camera for video calls.",
        "NSMicrophoneUsageDescription": "PingMe can use your microphone for voice and video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/icon.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 3,
      "predictiveBackGestureEnabled": false,
      "package": "com.huynhducphu.PingMe",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/app/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-video",
      "./plugins/withZegoMaven.js"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e14b7f4-deed-4d87-b898-4a8a57fe94fb"
      }
    },
    "owner": "huynhducphu"
  }
}